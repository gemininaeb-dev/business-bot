# --- Telegram ---
# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF_your_token_here

# Telegram ID администраторов (через запятую), получают уведомления о заявках
ADMIN_IDS=123456789

# --- База данных ---
# По умолчанию SQLite (файл рядом с проектом). Для прода:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./business_bot.db

# --- Веб-панель ---
# Логин и пароль для входа в админ-панель
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_please
# Секрет для подписи сессионных cookie (любая длинная случайная строка)
SECRET_KEY=please_generate_a_long_random_secret_string

# Хост и порт веб-сервера
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Название бизнеса (отображается в боте и панели)
BUSINESS_NAME=Моя Кофейня
